{
  "buildCommand": "npm install && npm run build:css",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/lead-magnet", "destination": "/mba", "permanent": true },
    { "source": "/lead-magnet.html", "destination": "/mba", "permanent": true },
    { "source": "/vault", "destination": "/mba", "permanent": false },
    { "source": "/free", "destination": "/mba", "permanent": false },
    { "source": "/offer", "destination": "/mba", "permanent": false },
    { "source": "/community", "destination": "https://www.skool.com/vibe-marketing", "permanent": false },
    { "source": "/skool", "destination": "https://www.skool.com/vibe-marketing", "permanent": false },
    { "source": "/community-offer", "destination": "/community", "permanent": false },
    { "source": "/join", "destination": "/community", "permanent": false },
    { "source": "/upsell", "destination": "/community", "permanent": false },
    { "source": "/call", "destination": "https://aisimple.co/#book", "permanent": false },
    { "source": "/book", "destination": "https://aisimple.co/#book", "permanent": false },
    { "source": "/blueprint", "destination": "/employee-setup", "permanent": false },
    { "source": "/ai-employee", "destination": "/employee-setup", "permanent": false },
    { "source": "/leveragedcre", "destination": "/cre", "permanent": false },
    { "source": "/phill", "destination": "/cre", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://unpkg.com https://assets.calendly.com https://cdn.jsdelivr.net https://www.googletagmanager.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://assets.calendly.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self' https:; frame-src https://calendly.com https://www.youtube.com;" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
